{
  "buildCommand": "pnpm install && pnpm --filter @workspace/csa-2026 run build",
  "outputDirectory": "artifacts/csa-2026/public",
  "installCommand": "pnpm install",
  "framework": null,
  "env": {
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
